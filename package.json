{
  "name": "beautiful-css",
  "type": "module",
  "version": "1.0.0",
  "description": "Beautiful web components for JavaScript and CSS",
  "main": "./dist/index.js",
  "types": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm-run-all clean-dist js js-minify css css-minify post-clean",
    "clean-dist": "rm -rf dist/*",
    "js": "webpack --config webpack-js.config.js",
    "js-minify": "webpack --config webpack-js-minify.config.js",
    "css": "webpack --config webpack-css.config.js",
    "css-minify": "webpack --config webpack-css-minify.config.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "post-clean": "rm dist/*.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/btfcss/beautiful-css.git"
  },
  "keywords": [
    "CSS",
    "Web",
    "Components",
    "JavaScript",
    "UI"
  ],
  "author": "Beautiful CSS",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/btfcss/beautiful-css/issues"
  },
  "homepage": "https://github.com/btfcss/beautiful-css#readme",
  "devDependencies": {
    "css-loader": "^7.0.0",
    "css-minimizer-webpack-plugin": "^6.0.0",
    "glob": "^10.3.12",
    "mini-css-extract-plugin": "^2.8.1",
    "npm-run-all": "^4.1.5",
    "slugify": "^1.6.6",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-fix-style-only-entries": "^0.6.1"
  }
}
